  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:windows:portable": "tauri build --no-bundle",
    "tauri:windows:installer": "tauri build --bundles nsis",
    "tauri:macos": "tauri build --target universal-apple-darwin",
